# Drope — exemplo de variáveis de ambiente
# Copie este arquivo pra .env.local e preencha os valores
# (no Vercel use Settings → Environment Variables; localmente, vercel env pull)

# ============ SUPABASE ============
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_ANON_KEY=

# ============ IA ============
CLAUDE_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=

# ============ WhatsApp (UazAPI) ============
UAZAPI_SERVER=https://dropepod.uazapi.com
UAZAPI_TOKEN=

# ============ Pagamentos ============
INFINITEPAY_WEBHOOK_SECRET=
MP_ACCESS_TOKEN=

# ============ Busca / Enrichment ============
SERPER_API_KEY=
REMOVEBG_API_KEY=

# ============ Admin / Permissões ============
ADMIN_TOKEN=
ADMIN_LUCAS=5511962443565
ADMIN_CAIXA=
PDV_PHONES=
PDV_PIN=
CRON_TOKEN=

# ============ Operação ============
EXPIRY_MINUTES=30
STORE_WHATS_NUMBER=
GRUPO_MOTOBOY_JID=
GRUPO_PDV_JID=

